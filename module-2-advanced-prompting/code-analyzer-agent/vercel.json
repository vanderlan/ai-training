{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/analyze/security",
      "dest": "api/index.ts"
    },
    {
      "src": "/api/analyze/performance",
      "dest": "api/index.ts"
    },
    {
      "src": "/api/analyze",
      "dest": "api/index.ts"
    },
    {
      "src": "/",
      "dest": "public/index.html"
    }
  ]
}
