# LLM Provider (deepseek | mock)
LLM_PROVIDER=deepseek

# DeepSeek API Key
DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_MODEL=deepseek-chat

# Optional tuning
ENABLE_LLM_PASS=true          # set to false to skip LLM analysis (regex-only, free)
RATE_LIMIT_RPM=3              # max GitHub analyze requests per minute per IP
CACHE_TTL_SECONDS=3600        # how long to cache repo analysis results (seconds)
LLM_TRIGGER_THRESHOLD=4.0     # minimum static score to trigger LLM pass (cost control)
DAILY_BUDGET_USD=5.0           # daily LLM cost cap in USD (approximate)
